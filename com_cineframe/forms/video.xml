<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="details">
        <field name="id" type="hidden" />

        <field
            name="title"
            type="text"
            label="COM_CINEFRAME_FIELD_TITLE_LABEL"
            description="COM_CINEFRAME_FIELD_TITLE_DESC"
            required="true"
            size="60"
        />

        <field
            name="catid"
            type="sql"
            label="COM_CINEFRAME_FIELD_CATID_LABEL"
            query="SELECT id AS value, name AS text FROM #__cineframe_categories WHERE published=1 ORDER BY ordering ASC, name ASC"
            key_field="value"
            value_field="text"
            default="0"
            first_option="COM_CINEFRAME_FIELD_CATID_NONE"
        />

        <field
            name="type"
            type="list"
            label="COM_CINEFRAME_FIELD_TYPE_LABEL"
            default="youtube"
            validate="options"
        >
            <option value="youtube">COM_CINEFRAME_TYPE_YOUTUBE</option>
            <option value="vimeo">COM_CINEFRAME_TYPE_VIMEO</option>
            <option value="video">COM_CINEFRAME_TYPE_VIDEO</option>
            <option value="embed">COM_CINEFRAME_TYPE_EMBED</option>
        </field>

        <field
            name="source"
            type="textarea"
            label="COM_CINEFRAME_FIELD_SOURCE_LABEL"
            description="COM_CINEFRAME_FIELD_SOURCE_DESC"
            rows="5"
            cols="60"
            required="true"
            filter="raw"
        />

        <field
            name="thumb"
            type="text"
            label="COM_CINEFRAME_FIELD_THUMB_LABEL"
            description="COM_CINEFRAME_FIELD_THUMB_DESC"
            size="80"
        />

        <field
            name="description"
            type="textarea"
            label="COM_CINEFRAME_FIELD_DESCRIPTION_LABEL"
            rows="4"
            cols="60"
        />

        <field
            name="width"
            type="number"
            label="COM_CINEFRAME_FIELD_WIDTH_LABEL"
            description="COM_CINEFRAME_FIELD_WIDTH_DESC"
            default="640"
            min="0"
        />

        <field
            name="published"
            type="list"
            label="COM_CINEFRAME_FIELD_STATUS_LABEL"
            default="1"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
        </field>
    </fieldset>
</form>
