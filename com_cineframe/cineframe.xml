<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade">
    <name>com_cineframe</name>
    <author>WebtechSolutions</author>
    <creationDate>2026-07</creationDate>
    <copyright>(C) 2026 WebtechSolutions</copyright>
    <license>GNU General Public License version 2 or later</license>
    <version>1.2.4</version>
    <description>COM_CINEFRAME_XML_DESCRIPTION</description>
    <namespace path="src">Webtech\Component\Cineframe</namespace>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>
    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>
    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>

    <files folder="components/com_cineframe">
        <folder>language</folder>
        <folder>services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>

    <administration>
        <menu link="option=com_cineframe">COM_CINEFRAME</menu>
        <submenu>
            <menu link="option=com_cineframe&amp;view=videos">COM_CINEFRAME_SUBMENU_VIDEOS</menu>
            <menu link="option=com_cineframe&amp;view=categories">COM_CINEFRAME_SUBMENU_CATEGORIES</menu>
        </submenu>
        <files folder="administrator/components/com_cineframe">
            <folder>forms</folder>
            <folder>language</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
            <filename>access.xml</filename>
            <filename>cineframe.xml</filename>
        </files>
    </administration>
</extension>
