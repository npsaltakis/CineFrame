    <name>PLG_CONTENT_CINEFRAME</name>
    <author>WebtechSolutions</author>
    <creationDate>2026-07</creationDate>
    <copyright>(C) 2026 WebtechSolutions</copyright>
    <license>GNU General Public License version 2 or later</license>
    <version>1.2.4</version>
    <description>PLG_CONTENT_CINEFRAME_XML_DESCRIPTION</description>
    <namespace path="src">Webtech\Plugin\Content\Cineframe</namespace>
    <files>
        <folder plugin="cineframe">services</folder>
        <folder>src</folder>
        <folder>language</folder>
    </files>
    <media destination="plg_content_cineframe" folder="media">
        <folder>css</folder>
    </media>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="default_width"
                    type="number"
                    label="PLG_CONTENT_CINEFRAME_FIELD_DEFAULT_WIDTH_LABEL"
                    description="PLG_CONTENT_CINEFRAME_FIELD_DEFAULT_WIDTH_DESC"
                    default="640"
                />
            </fieldset>
        </fields>
    </config>
</extension>
